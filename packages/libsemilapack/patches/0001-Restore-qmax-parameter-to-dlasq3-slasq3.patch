+void dlasq3_(INT* i0, INT* n0, f64* Z, INT* pp, f64* dmin, f64* sigma, f64* desig, f64* qmax, INT* nfail, INT* iter, INT* ndiv, INT* ieee, INT* ttype, f64* dmin1, f64* dmin2, f64* dn, f64* dn1, f64* dn2, f64* g, f64* tau);
