Date: Mon, 16 Feb 2026 14:22:13 +0100
Subject: [PATCH 01/01] fix: remove relative path from tools.maturin

Recent maturin version doesn't path starting with ./

---
 lakers-python/pyproject.toml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index de40484..1a2af19 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -3,7 +3,7 @@ requires = ["maturin>=1.0,<2.0"]
 build-backend = "maturin"
 
 [tool.maturin]
-include = ["./examples/*"]
+include = ["examples/*"]
 
 [project]
 name = "lakers-python"
